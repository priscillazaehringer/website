{
  "rewrites": [
    { "source": "/home", "destination": "/home.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/podcast", "destination": "/podcast.html" },
    { "source": "/ads", "destination": "/ads.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }]
    }
  ]
}
